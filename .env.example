# ── Engine ──────────────────────────────────────────────────────────────────
# "groq"        = Groq Whisper API  (requires GROQ_API_KEY, high accuracy)
# "google"      = Google Speech API direct, no Chrome needed  (free, unofficial)
# "google-ext"  = Chrome Extension + Offscreen Doc  (free, requires Chrome in background)
ENGINE=groq

# ── Groq settings (only needed when ENGINE=groq) ─────────────────────────────
# Get a free key at https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here
MODEL=whisper-large-v3-turbo

# ── Shared settings ───────────────────────────────────────────────────────────
HOTKEY=win+alt
LANGUAGE=fa

# ── Google engine settings (only needed when ENGINE=google) ──────────────────
# Port for WebSocket bridge between Python and Chrome extension
# Must match WS_PORT constant in extension/offscreen.js
WS_PORT=9137
